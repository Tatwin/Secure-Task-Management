{
  "name": "secure-task-dashboard",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.5.2",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "fix-db": "npm run build --workspace=@repo/shared && npm run prisma:generate --workspace=server && npm run prisma:push --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "turbo": "^2.0.0"
  }
}