{
    "version": 2,
    "builds": [
        {
            "src": "apps/client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "apps/server/src/index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/auth/(.*)",
            "dest": "apps/server/src/index.ts"
        },
        {
            "src": "/tasks/(.*)",
            "dest": "apps/server/src/index.ts"
        },
        {
            "src": "/api-docs/(.*)",
            "dest": "apps/server/src/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "apps/client/$1"
        }
    ]
}